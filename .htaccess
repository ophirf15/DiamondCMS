<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive Laravel app paths when the app root is the web root.
    # Do NOT blanket-block ^storage/ — public media is served at /storage/*.
    RewriteRule ^(app|bootstrap|config|database|resources|routes|tests|vendor|scripts)/ - [F,L,NC]
    RewriteRule ^(\.env|artisan|composer\.(json|lock)|phpunit\.xml|phpstan\.neon|pint\.json) - [F,L,NC]

    # Block direct browsing of private storage trees (not public media URLs).
    RewriteRule ^storage/(app|framework|logs)(/|$) - [F,L,NC]

    # Route everything else into Laravel's public folder.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

DirectoryIndex index.php

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php85” package as the default “PHP” programming language.
# After deploy: MultiPHP Manager → Apply may rewrite this block — keep whatever cPanel writes.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php85___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
