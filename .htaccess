<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to sensitive paths when the app root is the docroot.
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor|scripts)/ - [F,L,NC]
    RewriteRule ^(\.env|artisan|composer\.(json|lock)|phpunit\.xml|phpstan\.neon|pint\.json) - [F,L,NC]

    # Serve the Laravel public/ directory.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

DirectoryIndex index.php
